<launch>
    <arg name="init_position" default="[-2, 3, 1.57]" />
    <arg name="goal_position" default="[0, 10]" />
    <node name="planner" pkg="navigation_pkg" type="planner.py" output="screen">
        <rosparam param="init_position" subst_value="True">$(arg init_position)</rosparam>
        <rosparam param="goal_position" subst_value="True">$(arg goal_position)</rosparam>
    </node>

    <!-- <node name="laserline" pkg="laserline" type="laserline">
        <param name="~frame_id" value="laser" />
        <param name="~scan_topic" value="/front/scan" />
        <param name="~frequency" value="40.0" />
        <param name="~show_lines" value="true" />
        <param name="~least_thresh" value="0.03" />
        <param name="~min_line_length" value="0.6" />
        <param name="~predict_distance" value="0.1" />
        <param name="~seed_line_points" value="6" />
        <param name="~min_line_points" value="10" />
    </node> -->
</launch>